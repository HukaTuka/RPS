<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="rps.gui.controller.GameViewController">
    <top>
        <Label text="Rock Paper Scissors"
               style="-fx-font-size: 24px; -fx-font-weight: bold;"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>
        <VBox spacing="20" alignment="CENTER">

            <!-- Buttons -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="Rock" onAction="#handleRock"/>
                <Button text="Paper" onAction="#handlePaper"/>
                <Button text="Scissors" onAction="#handleScissors"/>
            </HBox>

            <!-- Choices Display -->
            <VBox spacing="10" alignment="CENTER">
                <Label fx:id="playerChoiceLabel" text="Your Choice: -" />
                <Label fx:id="computerChoiceLabel" text="Computer Choice: -" />
            </VBox>

            <!-- Result -->
            <Label fx:id="resultLabel"
                   text="Result will appear here"
                   style="-fx-font-size: 18px; -fx-text-fill: blue;"/>

            <!-- Score -->
            <HBox spacing="20" alignment="CENTER">
                <Label fx:id="playerScoreLabel" text="Player: 0"/>
                <Label fx:id="computerScoreLabel" text="Computer: 0"/>
            </HBox>

        </VBox>
    </center>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

</BorderPane>